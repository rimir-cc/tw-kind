\procedure kind.cascade-add-cf-to-kind(target-tid, cf-tid)
<$let cf-def={{{ [<cf-tid>get[def]] }}} cf-key={{{ [<cf-tid>get[def]jsonget[key]] }}} next-idx={{{ [<target-tid>get[kind.fields]jsonindexes[]count[]] }}}>
<$action-setfield $tiddler=<<target-tid>> kind.fields={{{ [<target-tid>get[kind.fields]jsonset:json<next-idx>,<cf-def>] }}}/>
<$list filter="[<cf-key>!is[blank]]">
<$action-listops $tiddler=<<target-tid>> $field="kind.stream-fields" $subfilter="+[remove<cf-key>] +[append<cf-key>]"/>
</$list>
</$let>
\end

\procedure kind.cascade-create-kind(key)
<$list filter="[<key>!is[blank]]">
<$action-createtiddler $basetitle={{{ [[$:/config/rimir/kind/types/]] +[addsuffix<key>] }}} kind.type=<<key>> kind.icon="🆕" kind.title-formula="[get[parent]][[/]][get[abbrev]]+[join[]]" kind.fields="[]" kind.stream-fields="" type="text/vnd.tiddlywiki"/>
</$list>
\end

\procedure kind.cascade-finalize-new-field(target-tid, idx)
<$let field-key={{{ [<target-tid>get[kind.fields]jsonget<idx>,[key]] }}}>
<$action-setfield $tiddler=<<target-tid>> kind.fields={{{ [<target-tid>get[kind.fields]jsonset<idx>,[typed],[text]] }}}/>
<$list filter="[<field-key>!is[blank]]">
<$action-listops $tiddler=<<target-tid>> $field="kind.stream-fields" $subfilter="+[remove<field-key>] +[append<field-key>]"/>
</$list>
</$let>
\end

\procedure kind.cascade-delete-field(target-tid, idx)
<$let field-key={{{ [<target-tid>get[kind.fields]jsonget<idx>,[key]] }}}>
<$action-setfield $tiddler=<<target-tid>> kind.fields={{{ [function[kind.rebuilt-fields-without],<target-tid>,<idx>] }}}/>
