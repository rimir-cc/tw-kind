\procedure kind.apply-defaults-to(type-tid, target-tid)
<!-- Walks the type's fields and writes each field's `default` (with %TODAY% / %NOW%
     token expansion) onto the target tiddler — only for fields that are currently
     blank. Idempotent: existing non-blank field values are preserved.
     Also stamps `kind.type` on the target so the draft is a recognisable kind-
     instance for downstream consumers (e.g. the side-preview's instance-view
     template, which gates on `kind.type !is[blank]`). The downstream save path
     overwrites `kind.type` explicitly with the same value, so this is harmless.
     Tokens expand to TW canonical 17-char date format so date/datetime fields
     stay readable by $edit-date and format:date[] (display formatting is done
     by the view layer — kind uses DD.MM.YYYY / DD.MM.YYYY HH:mm). -->
<$action-setfield $tiddler=<<target-tid>> kind.type={{{ [<type-tid>get[kind.type]] }}}/>
<$let _today=<<now "YYYY0MM0DD000000000">> _nowts=<<now "YYYY0MM0DD0hh0mm0ss0XXX">>>
<$list filter="[function[kind.field-keys],<type-tid>]" variable="field-key">
<$let raw-default={{{ [function[kind.field-default],<type-tid>,<field-key>] }}}>
<$list filter="[<raw-default>!is[blank]] :filter[<target-tid>!has<field-key>] +[first[]]" variable="_">
<$action-setfield $tiddler=<<target-tid>> $field=<<field-key>> $value={{{ [<raw-default>search-replace[%TODAY%],<_today>search-replace[%NOW%],<_nowts>] }}}/>
</$list>
</$let>
</$list>
</$let>
\end

\procedure kind.apply-auto-children(parent-tid, type-tid)
<!-- Walks the parent type's `kind.auto-children` JSON array and creates each
     listed child instance with `parent: <<parent-tid>>` + per-entry field
     overrides + the child kind's own field defaults applied. The child's
     `kind.title-formula` evaluates against the draft (so it sees the pre-set
     parent + overrides). Called by every "save parent instance" path after
     the parent tiddler exists. Entries pointing at non-existent kinds are
     skipped silently. NOT recursive — auto-children of auto-children don't
     fire (the child create here uses $action-createtiddler directly, not a
     save-path that calls this procedure). Keeps shared state simple. -->
<$list filter="[function[kind.auto-children-indexes],<type-tid>]" variable="ac-idx">
<$let child-kind-key={{{ [function[kind.auto-child-kind-at],<type-tid>,<ac-idx>] }}}>
<$let
  child-type-tid={{{ [function[kind.locate-type],<child-kind-key>] }}}
  child-draft={{{ [[$:/state/rimir/kind/__auto-child-draft/]] +[addsuffix<parent-tid>] +[addsuffix[/]] +[addsuffix<ac-idx>] }}}
>
<$list filter="[<child-type-tid>!is[blank]]">
<$transclude $variable="kind.apply-defaults-to" type-tid=<<child-type-tid>> target-tid=<<child-draft>>/>
<$action-setfield $tiddler=<<child-draft>> parent=<<parent-tid>>/>
<$list filter="[function[kind.auto-child-fields-at],<type-tid>,<ac-idx>]" variable="fk">
<$action-setfield $tiddler=<<child-draft>> $field=<<fk>> $value={{{ [function[kind.auto-child-field-value-at],<type-tid>,<ac-idx>,<fk>] }}}/>
</$list>
<$action-createtiddler $basetitle={{{ [function[kind.eval-title],<child-type-tid>,<child-draft>] }}} $template=<<child-draft>> kind.type=<<child-kind-key>>/>
<$action-deletetiddler $tiddler=<<child-draft>>/>
</$list>
</$let>
</$let>
</$list>
\end

\procedure kind.force-apply-defaults(type-tid, target-tid)
<!-- Like kind.apply-defaults-to but unconditional: writes every default-bearing
     field onto target-tid regardless of current state. Used by the Reset row
     where the caller has just deleted target-tid (so "preserve existing values"
     would be incorrect — we WANT to overwrite, and the deletetiddler runs in
     the same action chain as this transclude). The `:filter[!has<field>]` gate
     used in apply-defaults-to evaluates AT RENDER TIME against the pre-delete
     state, which made reset toggle between "all defaults" and "empty" on repeat
     clicks. Dropping the gate makes the action idempotent across clicks.
     Also stamps `kind.type` so the freshly-deleted draft is recognised as a
     kind-instance by the side-preview after Reset. -->
<$action-setfield $tiddler=<<target-tid>> kind.type={{{ [<type-tid>get[kind.type]] }}}/>
<$let _today=<<now "YYYY0MM0DD000000000">> _nowts=<<now "YYYY0MM0DD0hh0mm0ss0XXX">>>
<$list filter="[function[kind.field-keys],<type-tid>]" variable="field-key">
<$let raw-default={{{ [function[kind.field-default],<type-tid>,<field-key>] }}}>
<$list filter="[<raw-default>!is[blank]]" variable="_">
<$action-setfield $tiddler=<<target-tid>> $field=<<field-key>> $value={{{ [<raw-default>search-replace[%TODAY%],<_today>search-replace[%NOW%],<_nowts>] }}}/>
</$list>
</$let>
