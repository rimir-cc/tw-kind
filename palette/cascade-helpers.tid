\procedure kind.cascade-set-constraint-num(target-tid, idx, prefix, value)
<$list filter="[<value>] ~[[]] +[is[blank]] [<value>regexp{$:/plugins/rimir/kind/_patterns!!digits}] +[first[]]">
<$let new-constraints={{{ [function[kind.computed-constraints-with-valid-picked],<target-tid>,<idx>,<prefix>,<value>] }}}>
<$action-setfield $tiddler=<<target-tid>> kind.fields={{{ [<target-tid>get[kind.fields]jsonset:json<idx>,[constraints],<new-constraints>] }}}/>
</$let>
</$list>
\end

\procedure kind.cascade-append-array-value(target-tid, idx, prop, value)
<$list filter="[<value>!is[blank]]">
<$let new-array={{{ [<target-tid>get[kind.fields]jsonindexes<idx>,<prop>] :map[<target-tid>get[kind.fields]jsonget<idx>,<prop>,<currentTiddler>] [<value>] +[unique[]] :map[function[kind.quote-string],<currentTiddler>] +[join[,]] :map[function[kind.wrap-array],<currentTiddler>] ~[function[kind.empty-array]] }}}>
<$action-setfield $tiddler=<<target-tid>> kind.fields={{{ [<target-tid>get[kind.fields]jsonset:json<idx>,<prop>,<new-array>] }}}/>
</$let>
</$list>
\end

\procedure kind.cascade-move-field(target-tid, idx, dir)
<$let
  other-idx={{{ [<idx>add<dir>] }}}
  count={{{ [<target-tid>get[kind.fields]jsonindexes[]count[]] }}}
>
<$list filter="[<other-idx>compare:integer:gteq[0]] +[!compare:integer:gteq<count>] +[first[]]">
<$let
  field-a={{{ [<target-tid>get[kind.fields]jsonextract<idx>] }}}
  field-b={{{ [<target-tid>get[kind.fields]jsonextract<other-idx>] }}}
>
<$action-setfield $tiddler=<<target-tid>> kind.fields={{{ [<target-tid>get[kind.fields]jsonset:json<idx>,<field-b>jsonset:json<other-idx>,<field-a>] }}}/>
</$let>
</$list>
</$let>
\end

\procedure kind.cascade-rename-field-key(target-tid, idx, old-key)
<$let new-key={{{ [<target-tid>get[kind.fields]jsonget<idx>,[key]] }}}>
<$list filter="[<new-key>!is[blank]] :filter[<new-key>!match<old-key>] +[first[]]">
<!-- Only swap in kind.stream-fields if old-key was actually listed there.
     Renames must not silently add an unrelated field to the inline bar. -->
<$list filter="[<target-tid>get[kind.stream-fields]enlist-input[]match<old-key>] +[first[]]">
<$action-listops $tiddler=<<target-tid>> $field="kind.stream-fields" $subfilter="+[remove<old-key>] +[remove<new-key>] +[append<new-key>]"/>
</$list>
</$list>
</$let>
\end
