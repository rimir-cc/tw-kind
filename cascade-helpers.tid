\procedure kind.cascade-create-here-init(host-tid, target-field, target-card, kind-tid)
<!-- Drill-open action for "Create here" rows: seeds the draft with defaults then
     pre-sets the back-ref so kind.eval-title sees the host's title in the Save row.
     The same seed runs again at save time as a safety net (idempotent). -->
<$let kind-type-key={{{ [<kind-tid>get[kind.type]] }}}>
<$let draft-tid={{{ [function[kind.create-here-draft-tid],<host-tid>,<target-field>,<kind-type-key>] }}}>
<$transclude $variable="kind.apply-defaults-to" type-tid=<<kind-tid>> target-tid=<<draft-tid>>/>
<%if [<target-card>match[multi]] %>
<$action-listops $tiddler=<<draft-tid>> $field=<<target-field>> $subfilter="+[append<host-tid>]"/>
<%else%>
<$action-setfield $tiddler=<<draft-tid>> $field=<<target-field>> $value=<<host-tid>>/>
<%endif%>
</$let>
</$let>
\end

\procedure kind.cascade-create-here(host-tid, target-field, target-card, kind-tid)
<!-- Save action for "Create here" Save row: writes the host's title into the new
     instance's back-ref field BEFORE $action-createtiddler $template, so the
     template copy includes the back-ref. kind.eval-title then sees it via the
     draft, matching the row-name preview that the drill-open init produced. -->
<$let kind-type-key={{{ [<kind-tid>get[kind.type]] }}}>
<$let draft-tid={{{ [function[kind.create-here-draft-tid],<host-tid>,<target-field>,<kind-type-key>] }}}>
<$transclude $variable="kind.apply-defaults-to" type-tid=<<kind-tid>> target-tid=<<draft-tid>>/>
<%if [<target-card>match[multi]] %>
<$action-listops $tiddler=<<draft-tid>> $field=<<target-field>> $subfilter="+[append<host-tid>]"/>
<%else%>
<$action-setfield $tiddler=<<draft-tid>> $field=<<target-field>> $value=<<host-tid>>/>
<%endif%>
<$action-createtiddler $basetitle={{{ [function[kind.eval-title],<kind-tid>,<draft-tid>] }}} $template=<<draft-tid>> kind.type=<<kind-type-key>>/>
<$action-deletetiddler $tiddler=<<draft-tid>>/>
</$let>
</$let>
\end
