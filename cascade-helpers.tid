\procedure kind.cascade-save-instance(kind-tid, draft-tid, type-key, keep-open)
<$let computed={{{ [function[kind.eval-title],<kind-tid>,<draft-tid>] }}}>
<%if [<keep-open>match[yes]] %>
<!-- Ctrl-Enter (mass-create): create the tiddler but KEEP the draft
     intact so the form stays populated for a quick follow-up entry.
     $action-createtiddler auto-uniquifies the basetitle on collision,
     so re-firing without changing fields yields "Name", "Name 1", …
     $savetitle captures the post-uniquification title; we then navigate
     to that — opens the new tiddler at the top of the story river
     behind the palette as visual confirmation. TW's tm-navigate doesn't
     focus the rendered tiddler frame, so the palette input keeps focus
     and the user can immediately Ctrl-Enter again for the next instance. -->
<$action-createtiddler $basetitle=<<computed>> $template=<<draft-tid>> kind.type=<<type-key>> $savetitle="$:/state/rimir/kind/__last-mass-create"/>
<$action-navigate $to={{$:/state/rimir/kind/__last-mass-create}}/>
<%else%>
<!-- Enter (single create): defensive apply-defaults (idempotent — fills
     only blank fields), create, clear the draft, navigate. Re-drilling
     "+ New <kind>" later re-seeds defaults via the drill's ca-actions. -->
<$transclude $variable="kind.apply-defaults-to" type-tid=<<kind-tid>> target-tid=<<draft-tid>>/>
<$action-createtiddler $basetitle=<<computed>> $template=<<draft-tid>> kind.type=<<type-key>>/>
<$action-deletetiddler $tiddler=<<draft-tid>>/>
<$action-navigate $to=<<computed>>/>
<%endif%>
</$let>
\end

