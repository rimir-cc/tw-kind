\function kind.create-here-save-leaf-json(target-kind-tid, host-tid, target-field, target-card, title) [<title>] +[addprefix[{"ca-name":"Save as \"]] +[addsuffix[\"","ca-icon":"💾","ca-kind":"leaf","ca-order":"1","ca-group":"Save","ca-after-fire":"pop","ca-hint":"Create the new instance with this entity linked into its back-reference field.","ca-actions":"<$transclude $variable=\"kind.cascade-create-here\" host-tid=\"]] +[addsuffix<host-tid>] +[addsuffix[\" target-field=\"]] +[addsuffix<target-field>] +[addsuffix[\" target-card=\"]] +[addsuffix<target-card>] +[addsuffix[\" kind-tid=\"]] +[addsuffix<target-kind-tid>] +[addsuffix[\"/>"}]]

